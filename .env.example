# Copy to .env and fill in your own keys. NEVER commit .env (it is gitignored).

# Your Black_Wall API key (free tier works). Get one at https://blackwalltier.com
# Used by the GATE arm (lib/gate.ts). Keys are prefixed bw_live_ or bw_test_.
BLACKWALL_API_KEY=

# Your Anthropic API key. Used by the RAW BASELINE arm (lib/baseline.ts) — the
# same bare-model control the Black_Wall benchmark page shows.
ANTHROPIC_API_KEY=

# Optional: override the gate base URL (default https://blackwalltier.com).
# BLACKWALL_BASE_URL=https://blackwalltier.com

# Optional knobs (see benchmarks/injecagent/README.md):
# REPS=5        # majority-vote reps per case
# DS_STRIP=1    # 1 = stripped DS floor (default); 0 = labeled upper bound
# DRY_RUN=1     # offline smoke path; no keys/network needed
